APP_NAME=RepoMind API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
SQLITE_DB_PATH=repomind.db
# Phase 1 — Embedding disk cache (paths relative to backend/ unless absolute)
VECTOR_CACHE_DIR=.cache/repomind/vectors
VECTOR_CACHE_TTL_SECONDS=604800
VECTOR_CACHE_MAX_MB=512
# Phase 2 (roadmap) — Retrieval depth (see docs/ADVANCEMENT_PHASES.md)
RETRIEVAL_CHUNK_STRATEGY=fixed
RETRIEVAL_CHUNK_SIZE=1200
RETRIEVAL_CHUNK_OVERLAP=150
RETRIEVAL_MAX_CHUNKS_PER_FILE=8
RETRIEVAL_EMBED_PATH_PREFIX=false
RETRIEVAL_FETCH_K=24
RETRIEVAL_ENABLE_RERANK=false
RETRIEVAL_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RETRIEVAL_ENABLE_HYDE=false
RETRIEVAL_HYDE_USE_LLM=true
CHAT_TOP_K=6
RETRIEVAL_ENABLE_METRICS_ENDPOINT=false
# Phase 3 — Bounded tool agent (retrieve / summarize / diagram); requires GEMINI or OPENROUTER
CHAT_AGENT_ENABLED=false
CHAT_AGENT_MAX_TOOL_ROUNDS=5
CHAT_AGENT_MAX_RETRIEVE_REFINES=2
CHAT_AGENT_MAX_LLM_CALLS=8
# Tests: deterministic planner (no live LLM), optional JSON array of tool dicts
# CHAT_AGENT_MOCK=1
# CHAT_AGENT_MOCK_STEPS=[{"tool":"answer"}]
# Phase 2 — Auth
# Generate a secure secret with: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080
# Phase 2 — GitHub OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
FRONTEND_URL=http://localhost:3000
# Phase 2 — Celery/Redis
REDIS_URL=redis://localhost:6379/0
